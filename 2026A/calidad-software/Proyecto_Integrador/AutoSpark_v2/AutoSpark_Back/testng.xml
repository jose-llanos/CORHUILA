<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="AutoSpark Selenium Suite" parallel="tests" thread-count="2">

    <!-- Pruebas en Chrome -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.autospark.migueljuliana.selenium.tests.RegisterTest"/>
            <class name="com.autospark.migueljuliana.selenium.tests.LoginTest"/>
            <class name="com.autospark.migueljuliana.selenium.tests.ServicesTest"/>
            <class name="com.autospark.migueljuliana.selenium.tests.ReservationTest"/>
        </classes>
    </test>

</suite>