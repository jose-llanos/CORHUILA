pipeline {
    agent any

    options {
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        SONAR_TOKEN   = credentials('sonar-token')
        E2E_BASE_URL  = 'http://app:8080'
        E2E_GRID_URL  = 'http://selenium-hub:4444'
        APP_CONTAINER = 'docker-app-1'
        PROJECT_DIR   = '2026A/calidad-software/talleres/tercer-corte'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Esperar a la app') {
            steps {
                sh '''
                    echo "Esperando app en ${E2E_BASE_URL}/actuator/health ..."
                    for i in $(seq 1 30); do
                        if curl -sf "${E2E_BASE_URL}/actuator/health" >/dev/null; then
                            echo "App OK"
                            exit 0
                        fi
                        echo "  intento $i/30..."
                        sleep 5
                    done

                    echo "App no respondió a tiempo"
                    exit 1
                '''
            }
        }

        stage('Unit Tests + JaCoCo') {
            steps {
                sh '''
                    docker exec ${APP_CONTAINER} \
                        ./mvnw -f /app/pom.xml clean verify
                '''
            }

            post {
                always {
                    sh '''
                        mkdir -p ${PROJECT_DIR}/app/target/surefire-reports ${PROJECT_DIR}/app/target/site
                        docker cp ${APP_CONTAINER}:/app/target/surefire-reports/. ${PROJECT_DIR}/app/target/surefire-reports/ || true
                        docker cp ${APP_CONTAINER}:/app/target/site/. ${PROJECT_DIR}/app/target/site/ || true
                    '''
                    junit allowEmptyResults: true, testResults: "${PROJECT_DIR}/app/target/surefire-reports/*.xml"
                    publishHTML(target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: "${PROJECT_DIR}/app/target/site/jacoco",
                        reportFiles: 'index.html',
                        reportName: 'JaCoCo Coverage'
                    ])
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        docker exec ${APP_CONTAINER} \
                            ./mvnw -f /app/pom.xml sonar:sonar \
                            -Dsonar.token=${SONAR_TOKEN}

                        mkdir -p ${PROJECT_DIR}/app/target/sonar
                        docker cp ${APP_CONTAINER}:/app/target/sonar/. ${PROJECT_DIR}/app/target/sonar/ || true
                    '''
                }
            }
        }

        stage('Esperar app antes de pruebas dinámicas') {
            steps {
                sh '''
                    for i in $(seq 1 30); do
                        if curl -sf "${E2E_BASE_URL}/actuator/health" >/dev/null; then
                            echo "App OK"
                            exit 0
                        fi
                        sleep 5
                    done

                    exit 1
                '''
            }
        }

        stage('JMeter Performance') {
            steps {
                sh '''
                    docker run --rm --network docker_qa-net \
                        -v jenkins-docker_jenkins_home:/var/jenkins_home \
                        -w /var/jenkins_home/workspace/pipeline/${PROJECT_DIR}/tests/jmeter \
                        justb4/jmeter:5.5 \
                        -n \
                        -t plan_de_carga.jmx \
                        -Jusers=10 \
                        -Jrampup=5 \
                        -Jduration=60 \
                        -l results.jtl \
                        -e \
                        -o report
                '''
            }

            post {
                always {
                    perfReport sourceDataFiles: "${PROJECT_DIR}/tests/jmeter/results.jtl"

                    publishHTML(target: [
                        allowMissing: true,
                        keepAll: true,
                        reportDir: "${PROJECT_DIR}/tests/jmeter/report",
                        reportFiles: 'index.html',
                        reportName: 'JMeter Report'
                    ])

                    archiveArtifacts(
                        artifacts: "${PROJECT_DIR}/tests/jmeter/results.jtl",
                        allowEmptyArchive: true
                    )
                }
            }
        }

        stage('Esperar al Selenium Grid') {
            steps {
                sh '''
                    for i in $(seq 1 30); do
                        if curl -sf "${E2E_GRID_URL}/status" | grep -q '"ready": *true'; then
                            echo "Grid OK"
                            exit 0
                        fi

                        echo "  intento $i/30..."
                        sleep 5
                    done

                    exit 1
                '''
            }
        }

        stage('E2E Tests (Selenium)') {
            steps {
                sh '''
                    docker exec \
                        -e E2E_BASE_URL=${E2E_BASE_URL} \
                        -e E2E_GRID_URL=${E2E_GRID_URL} \
                        ${APP_CONTAINER} \
                        ./mvnw -f /app/pom.xml test -Pe2e \
                        -De2e.baseUrl=${E2E_BASE_URL} \
                        -De2e.gridUrl=${E2E_GRID_URL}
                '''
            }

            post {
                always {
                    sh '''
                        mkdir -p ${PROJECT_DIR}/app/target/surefire-reports ${PROJECT_DIR}/app/target/screenshots
                        docker cp ${APP_CONTAINER}:/app/target/surefire-reports/. ${PROJECT_DIR}/app/target/surefire-reports/ || true
                        docker cp ${APP_CONTAINER}:/app/target/screenshots/. ${PROJECT_DIR}/app/target/screenshots/ || true
                    '''
                    junit(
                        allowEmptyResults: true,
                        testResults: "${PROJECT_DIR}/app/target/surefire-reports/*.xml"
                    )
                    archiveArtifacts(
                        artifacts: "${PROJECT_DIR}/app/target/screenshots/*.png",
                        allowEmptyArchive: true
                    )
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completo ✅'
        }
        failure {
            echo 'Pipeline falló — revisa reportes y screenshots.'
        }
    }
}