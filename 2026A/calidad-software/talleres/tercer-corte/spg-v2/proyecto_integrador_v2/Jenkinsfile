pipeline {
    agent any
    stages {
        stage('Verificar Servicios') {
            steps {
                echo '🔍 Verificando infraestructura del sistema...'
                sh '''
                    echo "Backend:" $(curl -s -o /dev/null -w "%{http_code}" http://backend:8080/api/auth/login)
                    echo "Frontend:" $(curl -s -o /dev/null -w "%{http_code}" http://frontend:80)
                    echo "SonarQube:" $(curl -s -o /dev/null -w "%{http_code}" http://sonarqube:9000)
                '''
                echo '✅ Infraestructura verificada'
            }
        }
        stage('Test Autenticacion JWT') {
            steps {
                echo '🔐 Probando flujo de autenticacion...'
                sh '''
                    TOKEN=$(curl -s -X POST http://backend:8080/api/auth/login \
                        -H "Content-Type: application/json" \
                        -d '{"email":"admin@sgplab.edu.co","password":"password"}' \
                        | grep -o '"token":"[^"]*"' | cut -d'"' -f4)
                    if [ -z "$TOKEN" ]; then
                        echo "FALLO: No se obtuvo token JWT"
                        exit 1
                    fi
                    echo "OK: Token JWT obtenido"
                    echo "$TOKEN" > /tmp/jwt_token.txt
                '''
            }
        }
        stage('Test API REST - CRUD Completo') {
            steps {
                echo '📋 Ejecutando pruebas CRUD sobre la API...'
                sh '''
                    TOKEN=$(cat /tmp/jwt_token.txt)
                    AUTH="Authorization: Bearer $TOKEN"
                    BASE="http://backend:8080/api"
                    PASS=0
                    FAIL=0

                    echo "--- GET /equipos ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/equipos)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- GET /usuarios ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/usuarios)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- GET /prestamos ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/prestamos)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- GET /penalizaciones ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/penalizaciones)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- POST /equipos (crear) ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST -H "$AUTH" -H "Content-Type: application/json" \
                        -d '{"nombre":"Equipo Jenkins Test","codigoInventario":"JNK-001","cantidad":1,"estado":"DISPONIBLE"}' \
                        $BASE/equipos)
                    if [ "$CODE" = "201" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- GET /equipos/1 ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/equipos/1)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- GET /usuarios/1 ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/usuarios/1)
                    if [ "$CODE" = "200" ]; then PASS=$((PASS+1)); echo "OK: $CODE"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- Test 404: GET /equipos/9999 ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -H "$AUTH" $BASE/equipos/9999)
                    if [ "$CODE" = "404" ]; then PASS=$((PASS+1)); echo "OK: $CODE (esperado)"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- Test 401: Sin token ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" $BASE/equipos)
                    if [ "$CODE" = "401" ]; then PASS=$((PASS+1)); echo "OK: $CODE (esperado)"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo ""
                    echo "========================================="
                    echo "  RESULTADOS: $PASS exitosos, $FAIL fallidos"
                    echo "========================================="
                    if [ "$FAIL" -gt 0 ]; then exit 1; fi
                '''
            }
        }
        stage('Test Validaciones') {
            steps {
                echo '🛡️ Probando validaciones del backend...'
                sh '''
                    TOKEN=$(cat /tmp/jwt_token.txt)
                    AUTH="Authorization: Bearer $TOKEN"
                    BASE="http://backend:8080/api"
                    PASS=0
                    FAIL=0

                    echo "--- POST /equipos sin datos (debe dar 400) ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST -H "$AUTH" -H "Content-Type: application/json" \
                        -d '{}' $BASE/equipos)
                    if [ "$CODE" = "400" ]; then PASS=$((PASS+1)); echo "OK: $CODE (esperado)"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- POST /auth/login sin datos (debe dar 400) ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST -H "Content-Type: application/json" \
                        -d '{}' $BASE/auth/login)
                    if [ "$CODE" = "400" ]; then PASS=$((PASS+1)); echo "OK: $CODE (esperado)"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo "--- POST /auth/login password incorrecto (debe dar 401) ---"
                    CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST -H "Content-Type: application/json" \
                        -d '{"email":"admin@sgplab.edu.co","password":"incorrecto"}' $BASE/auth/login)
                    if [ "$CODE" = "401" ]; then PASS=$((PASS+1)); echo "OK: $CODE (esperado)"; else FAIL=$((FAIL+1)); echo "FALLO: $CODE"; fi

                    echo ""
                    echo "========================================="
                    echo "  VALIDACIONES: $PASS exitosas, $FAIL fallidas"
                    echo "========================================="
                    if [ "$FAIL" -gt 0 ]; then exit 1; fi
                '''
            }
        }
        stage('Test Carga Ligero') {
            steps {
                echo '📈 Ejecutando prueba de carga ligera (20 requests)...'
                sh '''
                    TOKEN=$(cat /tmp/jwt_token.txt)
                    AUTH="Authorization: Bearer $TOKEN"
                    BASE="http://backend:8080/api"
                    OK=0
                    ERR=0
                    TOTAL_TIME=0

                    for i in $(seq 1 20); do
                        RESULT=$(curl -s -o /dev/null -w "%{http_code} %{time_total}" -H "$AUTH" $BASE/equipos)
                        CODE=$(echo $RESULT | cut -d' ' -f1)
                        TIME=$(echo $RESULT | cut -d' ' -f2)
                        if [ "$CODE" = "200" ]; then
                            OK=$((OK+1))
                        else
                            ERR=$((ERR+1))
                        fi
                    done

                    echo "========================================="
                    echo "  CARGA: $OK exitosos, $ERR errores de 20 requests"
                    echo "========================================="
                    if [ "$ERR" -gt 2 ]; then
                        echo "FALLO: Mas de 10% de errores"
                        exit 1
                    fi
                '''
            }
        }
        stage('Verificar SonarQube') {
            steps {
                echo '🔎 Verificando resultados en SonarQube...'
                sh '''
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://sonarqube:9000/api/system/status)
                    if [ "$STATUS" = "200" ]; then
                        echo "OK: SonarQube operativo"
                        HEALTH=$(curl -s http://sonarqube:9000/api/system/status | grep -o '"status":"[^"]*"')
                        echo "Estado: $HEALTH"
                    else
                        echo "ADVERTENCIA: SonarQube no disponible (HTTP $STATUS)"
                    fi

                    PROJECT=$(curl -s -u sqa_cfc36ff2017f809ae491f7ab64d8e0fdd0140c14: \
                        "http://sonarqube:9000/api/measures/component?component=com.sgplab:sgp-backend&metricKeys=bugs,vulnerabilities,code_smells,coverage,duplicated_lines_density")
                    echo "Metricas del proyecto:"
                    echo "$PROJECT" | grep -o '"metric":"[^"]*","value":"[^"]*"' | while read line; do
                        METRIC=$(echo $line | grep -o '"metric":"[^"]*"' | cut -d'"' -f4)
                        VALUE=$(echo $line | grep -o '"value":"[^"]*"' | cut -d'"' -f4)
                        echo "  $METRIC: $VALUE"
                    done
                '''
            }
        }
        stage('Reporte Final') {
            steps {
                echo ''
                echo '╔═══════════════════════════════════════════╗'
                echo '║     REPORTE FINAL - SGP LAB Pipeline     ║'
                echo '╠═══════════════════════════════════════════╣'
                echo '║ ✅ Infraestructura: OK                    ║'
                echo '║ ✅ Autenticacion JWT: OK                  ║'
                echo '║ ✅ API REST CRUD: OK                      ║'
                echo '║ ✅ Validaciones: OK                       ║'
                echo '║ ✅ Prueba de carga: OK                    ║'
                echo '║ ✅ SonarQube: Verificado                  ║'
                echo '╚═══════════════════════════════════════════╝'
            }
        }
    }
    post {
        success {
            echo '🎉 PIPELINE EXITOSO - Sistema SGP-LAB completamente verificado'
        }
        failure {
            echo '❌ PIPELINE FALLIDO - Revisar los logs de las etapas fallidas'
        }
    }
}