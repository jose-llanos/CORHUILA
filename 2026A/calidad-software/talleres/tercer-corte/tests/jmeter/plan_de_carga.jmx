                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.path">/api/projects/${PROJECT_SMALL_ID}/tasks/${TASK_S_NEW_ID}/assign</stringProp>
