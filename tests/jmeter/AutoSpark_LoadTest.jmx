        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.time.LocalDate
import java.time.LocalTime
import java.time.format.DateTimeFormatter
import java.util.concurrent.atomic.AtomicInteger

final String COUNTER_KEY = &quot;autospark.v6.unique.reservation.counter&quot;
final String RUN_OFFSET_KEY = &quot;autospark.v6.unique.reservation.run.offset.days&quot;

AtomicInteger counter
int runOffsetDays

synchronized (props) {
    Object counterObject = props.get(COUNTER_KEY)

    if (counterObject instanceof AtomicInteger) {
        counter = (AtomicInteger) counterObject
    } else {
        counter = new AtomicInteger(0)
        props.put(COUNTER_KEY, counter)
    }

    String offsetValue = props.getProperty(RUN_OFFSET_KEY)

    if (offsetValue == null) {
        long epochSeconds = Math.floorDiv(System.currentTimeMillis(), 1000L)
        runOffsetDays = 365 + (int) Math.floorMod(epochSeconds, 10000L)
        props.setProperty(RUN_OFFSET_KEY, String.valueOf(runOffsetDays))
    } else {
        runOffsetDays = Integer.parseInt(offsetValue)
    }
}

int slot = counter.incrementAndGet()
int zeroBasedSlot = slot - 1

int minutesPerDay = 540
int dayOffset = Math.floorDiv(zeroBasedSlot, minutesPerDay)
int minuteOffset = Math.floorMod(zeroBasedSlot, minutesPerDay)

LocalDate date = LocalDate.now().plusDays(runOffsetDays + dayOffset)
LocalTime time = LocalTime.of(8, 0).plusMinutes(minuteOffset)

vars.put(&quot;dynamicDate&quot;, date.format(DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)))
vars.put(&quot;dynamicTime&quot;, time.format(DateTimeFormatter.ofPattern(&quot;HH:mm:ss&quot;)))
vars.put(&quot;dynamicLicensePlate&quot;, &quot;TEST-&quot; + runOffsetDays + &quot;-&quot; + slot)
vars.put(&quot;dynamicValue&quot;, String.valueOf(25000 + Math.floorMod(slot, 125000)))</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
